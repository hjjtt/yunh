.intro-card {
  margin-bottom: 24rpx;
}

.search-box {
  height: 88rpx;
  margin-top: 26rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.filter-pill {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: var(--ink-medium);
  font-size: 24rpx;
}

.filter-pill.active {
  background: var(--ink-dark);
  color: #ffffff;
}

/* ========== 统计面板 ========== */
.stats-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.stat-card {
  padding: 24rpx;
  border-radius: 4rpx;
  border-left: 4rpx solid var(--accent);
  background-image: radial-gradient(#f5f3ef 1px, transparent 0);
  background-size: 20rpx 20rpx;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ink-dark);
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ========== 双列课程卡片 ========== */
.course-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.course-item {
  border-radius: 8rpx;
  overflow: hidden;
  border: 2rpx solid #dcd7c9;
  background: #ffffff;
  transition: all 0.2s ease;
}

.course-item:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

/* 封面 */
.course-cover {
  position: relative;
  height: 200rpx;
  overflow: hidden;
  background: #2c3e50;
  background-image: radial-gradient(rgba(255,255,255,0.08) 1px, transparent 0);
  background-size: 16rpx 16rpx;
}

.course-img {
  width: 100%;
  height: 100%;
}

.course-status {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.course-status.up {
  background: rgba(44,62,80,0.85);
  color: #ffffff;
}

.course-status.down {
  background: rgba(192,57,43,0.85);
  color: #ffffff;
}

/* 内容区 */
.course-body {
  padding: 18rpx;
}

.course-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink-dark);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  min-height: 72rpx;
}

.course-teacher {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #2c3e50;
  font-weight: 500;
}

.course-bottom {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 2rpx dashed var(--line);
}

.course-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #c0392b;
  font-family: "Times New Roman", serif;
}

.course-stock {
  font-size: 20rpx;
  color: var(--ink-light);
}

/* 空状态 */
.empty-text {
  text-align: center;
  padding: 60rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
}
