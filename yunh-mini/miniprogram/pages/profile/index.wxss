/* ========== 用户头像卡片 ========== */
.user-header {
  display: flex;
  align-items: center;
  padding: 40rpx 36rpx;
  background: #2c3e50;
  border-radius: 0 0 16rpx 16rpx;
  color: #ffffff;
}

.avatar-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #c0392b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  font-family: "Times New Roman", serif;
  color: #ffffff;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  margin-left: 28rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
}

.user-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
}

.user-role {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.85);
  flex-shrink: 0;
}

/* ========== 数据统计 ========== */
.stats-row {
  display: flex;
  align-items: center;
  margin: 28rpx 0;
  padding: 28rpx 0;
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-num {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--ink-dark);
}

.stats-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-light);
}

.stats-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--line);
  flex-shrink: 0;
}

/* ========== 快捷入口 ========== */
.shortcut-card {
  padding: 32rpx 16rpx;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
}

.shortcut-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.shortcut-item:active {
  opacity: 0.7;
}

.shortcut-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f5f9;
  position: relative;
}

.shortcut-text {
  font-size: 22rpx;
  color: var(--ink-medium);
}

/* 书本图标 */
.sc-book {
  width: 28rpx;
  height: 22rpx;
  border: 3rpx solid #2c3e50;
  border-radius: 0 4rpx 4rpx 0;
  position: relative;
}

.sc-book::before {
  content: "";
  position: absolute;
  left: -8rpx;
  top: -1rpx;
  width: 8rpx;
  height: 20rpx;
  border: 3rpx solid #2c3e50;
  border-right: none;
  border-radius: 3rpx 0 0 3rpx;
}

/* 订单图标 */
.sc-receipt {
  width: 24rpx;
  height: 28rpx;
  border: 3rpx solid #2c3e50;
  border-radius: 4rpx;
  position: relative;
}

.sc-receipt::before,
.sc-receipt::after {
  content: "";
  position: absolute;
  left: 4rpx;
  width: 12rpx;
  height: 2rpx;
  background: #2c3e50;
}

.sc-receipt::before { top: 8rpx; }
.sc-receipt::after { top: 16rpx; }

/* 指南针图标 */
.sc-compass {
  width: 26rpx;
  height: 26rpx;
  border: 3rpx solid #2c3e50;
  border-radius: 50%;
}

.sc-compass::after {
  content: "";
  display: block;
  width: 0;
  height: 0;
  margin: 4rpx auto 0;
  border-left: 5rpx solid transparent;
  border-right: 5rpx solid transparent;
  border-bottom: 10rpx solid #2c3e50;
}

/* 退出图标 */
.sc-exit {
  width: 24rpx;
  height: 20rpx;
  border: 3rpx solid #2c3e50;
  border-radius: 4rpx;
  position: relative;
}

.sc-exit::after {
  content: "";
  position: absolute;
  right: -12rpx;
  top: 4rpx;
  width: 10rpx;
  height: 2rpx;
  background: #2c3e50;
}

/* 笔记图标 */
.sc-note {
  width: 24rpx;
  height: 30rpx;
  border: 3rpx solid #2c3e50;
  border-radius: 3rpx;
  position: relative;
}

.sc-note::before {
  content: "";
  position: absolute;
  top: 8rpx;
  left: 5rpx;
  width: 14rpx;
  height: 2rpx;
  background: #2c3e50;
  box-shadow: 0 6rpx 0 #2c3e50;
}

/* 评论气泡图标 */
.sc-comment {
  width: 28rpx;
  height: 22rpx;
  border: 3rpx solid #2c3e50;
  border-radius: 6rpx;
  position: relative;
}

.sc-comment::after {
  content: "";
  position: absolute;
  bottom: -8rpx;
  left: 8rpx;
  width: 0;
  height: 0;
  border-left: 5rpx solid transparent;
  border-right: 5rpx solid transparent;
  border-top: 8rpx solid #2c3e50;
}

/* 问答问号图标 */
.sc-question {
  width: 26rpx;
  height: 26rpx;
  border: 3rpx solid #2c3e50;
  border-radius: 50%;
  position: relative;
}

.sc-question::after {
  content: "?";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -55%);
  font-size: 18rpx;
  font-weight: 700;
  color: #2c3e50;
  font-family: "Times New Roman", serif;
  line-height: 1;
}

/* 学习互动区域 */
.interaction-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink-dark);
  padding-left: 16rpx;
  border-left: 6rpx solid #c0392b;
  margin-bottom: 20rpx;
}

/* ========== 通用 section ========== */
.section-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink-dark);
  border-left: 6rpx solid #c0392b;
  padding-left: 16rpx;
}

.section-link {
  font-size: 24rpx;
  color: var(--ink-medium);
}

.section-link:active {
  color: var(--ink-dark);
}

.empty-hint {
  text-align: center;
  padding: 36rpx 0;
  font-size: 24rpx;
  color: var(--ink-light);
}

/* ========== 最近课程 ========== */
.course-list {
  display: flex;
  flex-direction: column;
}

.course-row {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
}

.course-row:last-child {
  border-bottom: none;
}

.course-row:active {
  background: #f8fafc;
}

.course-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2c3e50;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.course-info {
  flex: 1;
  min-width: 0;
}

.course-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--ink-dark);
}

.course-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--ink-light);
}

.course-arrow {
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 10rpx solid #cbd5e1;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ========== 最近订单 ========== */
.order-list {
  display: flex;
  flex-direction: column;
}

.order-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
}

.order-row:last-child {
  border-bottom: none;
}

.order-row:active {
  background: #f8fafc;
}

.order-body {
  flex: 1;
  min-width: 0;
}

.order-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--ink-dark);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-no {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--ink-light);
  font-family: "Courier New", monospace;
}

.order-status {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.order-status.paid {
  background: #ecfdf5;
  color: #059669;
}

.order-status.pending {
  background: #fef3c7;
  color: #d97706;
}
