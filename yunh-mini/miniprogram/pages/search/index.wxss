/* ========== 搜索栏 ========== */
.search-bar {
  margin-bottom: 22rpx;
  padding: 16rpx 24rpx !important;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-icon {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid var(--ink-light);
  border-radius: 50%;
  position: relative;
  flex-shrink: 0;
}

.search-icon::after {
  content: "";
  position: absolute;
  bottom: -10rpx;
  right: -10rpx;
  width: 12rpx;
  height: 4rpx;
  background: var(--ink-light);
  border-radius: 2rpx;
  transform: rotate(45deg);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--ink-dark);
  height: 56rpx;
}

.search-placeholder {
  color: var(--ink-light);
  font-size: 26rpx;
}

.search-clear {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--ink-light);
  position: relative;
  flex-shrink: 0;
}

.search-clear::before,
.search-clear::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 16rpx;
  height: 3rpx;
  background: #ffffff;
  border-radius: 2rpx;
}

.search-clear::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.search-clear::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.search-result-hint {
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: var(--ink-medium);
}

.search-keyword {
  color: var(--accent);
  font-weight: 600;
}

/* ========== 英雄区 ========== */
.discover-hero {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.discover-hero .card-dark {
  background: #2c3e50 !important;
  color: #ffffff !important;
}

.discover-hero .card-light {
  background: #fae1dd !important;
  color: #c0392b !important;
}

.hero-side-label {
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: #c0392b;
  font-family: "Times New Roman", serif;
  text-transform: uppercase;
}

.hero-side-value {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #2d3436;
}

.hero-side-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #636e72;
}

/* ========== 通用板块 ========== */
.section-card {
  margin-bottom: 28rpx;
}

.section-head {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-dark);
  border-left: 6rpx solid #c0392b;
  padding-left: 16rpx;
}

.section-kicker {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-light);
}

.empty-hint {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: var(--ink-light);
}

/* ========== 精选推荐 ========== */
.featured-banner {
  display: flex;
  overflow: hidden;
  border-radius: 8rpx;
  border: 2rpx solid #dcd7c9;
}

.featured-cover {
  position: relative;
  width: 260rpx;
  min-height: 240rpx;
  background: #2c3e50;
  background-image: radial-gradient(rgba(255,255,255,0.08) 1px, transparent 0);
  background-size: 16rpx 16rpx;
  flex-shrink: 0;
}

.featured-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 4rpx 12rpx;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: #ffffff;
  background: #c0392b;
  font-family: "Times New Roman", serif;
}

.featured-body {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background-image: radial-gradient(#f5f3ef 1px, transparent 0);
  background-size: 20rpx 20rpx;
}

.featured-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink-dark);
  line-height: 1.4;
}

.featured-desc {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--ink-medium);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.featured-meta {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.featured-teacher {
  font-size: 24rpx;
  color: #2c3e50;
  font-weight: 500;
}

.featured-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #c0392b;
  font-family: "Times New Roman", serif;
}

/* ========== 分类标签 ========== */
.category-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  border-radius: 8rpx;
  border: 2rpx solid var(--line);
  background: #ffffff;
  transition: all 0.2s ease;
}

.category-item.active {
  border-color: #2c3e50;
  background: #2c3e50;
  color: #ffffff;
}

.category-item.active .category-name {
  color: #ffffff;
}

.category-item.active .category-count {
  color: rgba(255,255,255,0.7);
}

.category-icon {
  font-size: 36rpx;
}

.category-name {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--ink-dark);
}

.category-count {
  margin-top: 4rpx;
  font-size: 18rpx;
  color: var(--ink-light);
}

/* ========== 热门课程 ========== */
.hot-list {
  display: flex;
  flex-direction: column;
}

.hot-item {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 2rpx solid var(--line);
}

.hot-item:last-child {
  border-bottom: none;
}

.hot-rank {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  font-family: "Times New Roman", serif;
  color: #ffffff;
  background: #2c3e50;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.hot-item:nth-child(1) .hot-rank {
  background: #c0392b;
}

.hot-item:nth-child(2) .hot-rank {
  background: #e67e22;
}

.hot-item:nth-child(3) .hot-rank {
  background: #f39c12;
}

.hot-info {
  flex: 1;
}

.hot-title {
  font-size: 28rpx;
  color: var(--ink-dark);
  font-weight: 500;
}

.hot-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--ink-medium);
}

.hot-arrow {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 12rpx solid var(--ink-light);
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ========== 讲师风采 ========== */
.teacher-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.teacher-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 8rpx;
  border: 2rpx solid var(--line);
  background-image: radial-gradient(#f5f3ef 1px, transparent 0);
  background-size: 20rpx 20rpx;
}

.teacher-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2c3e50;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  font-family: "Times New Roman", serif;
}

.teacher-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink-dark);
}

.teacher-stats {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--ink-medium);
}

/* ========== 全部课程网格 ========== */
.grid-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.grid-item {
  border-radius: 8rpx;
  overflow: hidden;
  border: 2rpx solid #dcd7c9;
  background: #ffffff;
  transition: all 0.2s ease;
}

.grid-item:active {
  transform: scale(0.97);
}

.grid-cover {
  position: relative;
  height: 160rpx;
  overflow: hidden;
  background: #2c3e50;
}

.grid-cover-img {
  width: 100%;
  height: 100%;
}

.grid-cover-label {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
  padding: 2rpx 10rpx;
  font-size: 18rpx;
  color: #ffffff;
  background: rgba(0,0,0,0.4);
  border-radius: 4rpx;
}

.grid-body {
  padding: 16rpx;
}

.grid-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ink-dark);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.grid-meta {
  margin-top: 8rpx;
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: var(--ink-medium);
}

.grid-price {
  color: #c0392b;
  font-weight: 700;
}
