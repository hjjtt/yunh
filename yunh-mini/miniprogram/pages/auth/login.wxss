/* ========== 全屏登录页 ========== */
.login-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at top left, rgba(197, 77, 65, 0.12), transparent 34%),
    radial-gradient(circle at top right, rgba(45, 61, 82, 0.14), transparent 30%),
    #f7f2eb;
}

.hero-orb {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(18rpx);
  opacity: 0.8;
}

.hero-orb-left {
  top: 120rpx;
  left: -80rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(197, 77, 65, 0.16);
}

.hero-orb-right {
  top: 220rpx;
  right: -60rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(45, 61, 82, 0.12);
}

.login-shell {
  position: relative;
  z-index: 1;
  box-sizing: border-box;
  min-height: 100vh;
  padding: calc(56rpx + env(safe-area-inset-top)) 28rpx calc(48rpx + env(safe-area-inset-bottom));
}

/* ========== 启动检测屏 ========== */
.splash-screen {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #253648 0%, #32485f 70%, #4f2e2c 100%);
}

.splash-logo {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #d26a5c 0%, #b3483b 100%);
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
  font-family: "Times New Roman", serif;
  letter-spacing: 2rpx;
  box-shadow: 0 16rpx 32rpx rgba(179, 72, 59, 0.26);
}

.splash-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.72);
  letter-spacing: 2rpx;
}

/* ========== 顶部欢迎区 ========== */
.login-hero {
  position: relative;
  padding: 42rpx 34rpx 110rpx;
  border-radius: 40rpx;
  background:
    linear-gradient(155deg, rgba(255, 255, 255, 0.08), transparent 45%),
    linear-gradient(145deg, #213345 0%, #31485f 58%, #9d4a40 150%);
  color: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(33, 51, 69, 0.18);
  overflow: hidden;
}

.login-hero::before {
  content: "";
  position: absolute;
  top: 0;
  right: 0;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.18) 0%, transparent 68%);
  transform: translate(30%, -30%);
}

.login-hero::after {
  content: "";
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 28rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0));
}

.brand-badge {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 237, 230, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  color: #ffe2dc;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  font-family: "Times New Roman", serif;
}

.hero-headline {
  margin-top: 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.brand-title {
  font-size: 60rpx;
  line-height: 1.1;
  font-weight: 700;
  font-family: "Times New Roman", "PingFang SC", serif;
  letter-spacing: 2rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
}

.brand-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(255, 244, 240, 0.84);
  letter-spacing: 6rpx;
}

.brand-desc {
  margin-top: 22rpx;
  max-width: 540rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.72);
}

/* ========== 登录卡片 ========== */
.login-card {
  position: relative;
  margin: -56rpx 12rpx 0;
  padding: 34rpx 28rpx 30rpx;
  border-radius: 34rpx;
  background: rgba(255, 252, 248, 0.96);
  border: 1rpx solid rgba(223, 215, 202, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(102, 84, 67, 0.12);
  backdrop-filter: blur(8rpx);
}

.login-card::before {
  content: "";
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 0;
  height: 10rpx;
  border-radius: 0 0 999rpx 999rpx;
  background: linear-gradient(90deg, #b3483b 0%, #d27c6d 100%);
}

.card-header {
  margin-bottom: 26rpx;
}

.card-title {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #243447;
}

.card-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #8a7f73;
}

.form-section {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.field-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field-label {
  padding-left: 4rpx;
  font-size: 23rpx;
  font-weight: 600;
  color: #5d564c;
  letter-spacing: 1rpx;
}

.form-group {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: #fffdfa;
  border: 2rpx solid #dfd7ca;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  box-sizing: border-box;
}

.captcha-group {
  align-items: stretch;
}

.form-icon {
  width: 36rpx;
  height: 36rpx;
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-user-head {
  position: absolute;
  top: 0;
  left: 8rpx;
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid #96897c;
  border-radius: 50%;
}

.icon-user-body {
  position: absolute;
  bottom: 0;
  left: 2rpx;
  width: 30rpx;
  height: 12rpx;
  border: 2rpx solid #96897c;
  border-radius: 10rpx 10rpx 0 0;
  border-bottom: none;
}

.form-icon.icon-lock {
  width: 24rpx;
  height: 28rpx;
  border: 2rpx solid #96897c;
  border-radius: 6rpx;
  position: relative;
}

.form-icon.icon-lock::before {
  content: "";
  position: absolute;
  top: -14rpx;
  left: 3rpx;
  width: 12rpx;
  height: 12rpx;
  border: 2rpx solid #96897c;
  border-bottom: none;
  border-radius: 8rpx 8rpx 0 0;
}

.form-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #243447;
}

.captcha-input {
  padding-right: 12rpx;
}

.toggle-pwd {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  margin-left: 12rpx;
  border-radius: 50%;
  background: #f4eee5;
  flex-shrink: 0;
}

.eye {
  width: 28rpx;
  height: 18rpx;
  border: 2rpx solid #8a7f73;
  border-radius: 50%;
  position: relative;
}

.eye::after {
  content: "";
  position: absolute;
  top: 5rpx;
  left: 8rpx;
  width: 8rpx;
  height: 8rpx;
  background: #8a7f73;
  border-radius: 50%;
}

.eye.open {
  border-color: #b3483b;
}

.eye.open::after {
  background: #b3483b;
}

.captcha-box {
  align-self: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 174rpx;
  height: 72rpx;
  margin-left: 12rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #32485f 0%, #243447 100%);
  box-shadow: 0 10rpx 22rpx rgba(36, 52, 71, 0.16);
  flex-shrink: 0;
}

.captcha-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
  font-family: "Times New Roman", serif;
}

.captcha-refresh {
  margin-top: 4rpx;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.66);
}

.login-btn {
  margin-top: 30rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 24rpx !important;
  border: none !important;
  background: linear-gradient(135deg, #cf6a5e 0%, #b3483b 100%) !important;
  color: #ffffff !important;
  font-size: 30rpx !important;
  font-weight: 700 !important;
  letter-spacing: 4rpx;
  box-shadow: 0 16rpx 26rpx rgba(179, 72, 59, 0.22);
}

.login-btn::after {
  border: none !important;
}

.login-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 8rpx 16rpx rgba(179, 72, 59, 0.18);
  filter: brightness(0.97);
}

.login-tip {
  margin-top: 18rpx;
  text-align: center;
  font-size: 22rpx;
  line-height: 1.7;
  color: #8a7f73;
}
