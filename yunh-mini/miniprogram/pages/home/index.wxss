.hero-shell {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 22rpx;
}

/* 入场动画 */
@keyframes slideUpIn {
  from {
    transform: translateY(30rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}
/* 课程列表从左侧滑入动画 */
@keyframes slideInLeft {
  from {
    transform: translateX(-30rpx);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}
/* 网点微浮动动画（极慢，几乎不可察觉的动态感） */
@keyframes dotFloat {
  0% {
    background-position: 0 0, 10rpx 10rpx;
  }
  100% {
    background-position: 100rpx 100rpx, 110rpx 110rpx;
  }
}

/* ========== 课程画报列表优化 ========== */
/* 列表项交错入场动画 */
.course-item {
  transition: all 0.25s ease;
  opacity: 0;
  border-left: 4rpx solid transparent;
}
/* 错开入场时间，形成流水效果 */
.course-item:nth-child(1) { animation: slideInLeft 0.5s ease 0.2s forwards; }
.course-item:nth-child(2) { animation: slideInLeft 0.5s ease 0.3s forwards; }
.course-item:nth-child(3) { animation: slideInLeft 0.5s ease 0.4s forwards; }
.course-item:nth-child(4) { animation: slideInLeft 0.5s ease 0.5s forwards; }
.course-item:nth-child(5) { animation: slideInLeft 0.5s ease 0.6s forwards; }

/* 点击动效：轻微上浮，左侧装订线变色 */
.course-item:active {
  transform: translateY(-4rpx) scale(1.01);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
  border-left-color: var(--accent);
}

/* 序号优化：大号斜体衬线字，复古杂志感 */
.course-index {
  font-size: 64rpx;
  font-family: "Times New Roman", serif;
  font-style: italic;
  font-weight: 700;
  color: rgba(44, 62, 80, 0.12);
  line-height: 1;
  transition: all 0.2s ease;
}
.course-item:active .course-index {
  color: var(--accent);
  transform: translateX(4rpx);
}

/* 老师名字标签化 */
.course-teacher {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: var(--accent-light);
  color: var(--accent);
  border-radius: 2rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin: 8rpx 0;
  font-family: "PingFang SC", sans-serif;
}

.hero,
.hero-panel {
  border-radius: 4rpx;
  padding: 34rpx 34rpx 34rpx 42rpx;
  color: #ffffff;
  position: relative;
  overflow: hidden;
  /* 左侧装订边 */
  border-left: 8rpx solid var(--accent);
  /* 网点印刷纹理 */
  background-image: radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 0);
  background-size: 16rpx 16rpx;
  /* 通用动效 */
  transition: all 0.2s ease;
  animation: dotFloat 20s linear infinite;
}

.hero {
  min-height: 420rpx;
  background: #2c3e50 !important;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  /* 入场动画：先出现 */
  animation: slideUpIn 0.5s ease forwards, dotFloat 20s linear infinite;
}

.hero-panel {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: #c0392b !important;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  /* 入场动画：晚0.1秒出现，错开层次 */
  animation: slideUpIn 0.5s ease 0.1s forwards, dotFloat 20s linear infinite;
  opacity: 0;
}

/* 按压动效：模拟按在纸张上的感觉 */
.hero:active, .hero-panel:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
  filter: brightness(0.95);
}

.hero-panel-label {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  opacity: 0.9;
  font-family: "Times New Roman", serif;
  text-transform: uppercase;
}

.hero-panel-title {
  margin-top: 22rpx;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
  font-family: "Times New Roman", serif;
  /* 标题下划线 */
  padding-bottom: 8rpx;
  background: linear-gradient(to right, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0.8) 100rpx, transparent 100rpx) no-repeat left bottom;
  background-size: 100% 2rpx;
}

.hero-panel-desc {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.9;
}

.hero-panel-meta {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 22rpx;
  opacity: 0.85;
  font-family: "Times New Roman", serif;
}

.hero-actions {
  margin-top: 32rpx;
  display: flex;
  gap: 18rpx;
}

.hero-topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hero-kicker {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  opacity: 0.85;
  font-family: "Times New Roman", serif;
}

.hero-title {
  max-width: 560rpx;
  font-family: "Times New Roman", serif;
}

.hero-subtitle {
  max-width: 560rpx;
  opacity: 0.9;
}

.hero-ribbon {
  margin-top: 28rpx;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  opacity: 0.7;
  font-family: "Times New Roman", serif;
  text-transform: uppercase;
  /* 装饰点 */
  padding-left: 20rpx;
  position: relative;
}
.hero-ribbon::before {
  content: "•";
  position: absolute;
  left: 0;
  top: 0;
}

.light {
  background: rgba(255, 255, 255, 0.15);
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.6);
  font-family: "Times New Roman", serif;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.metric-card {
  padding: 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fffaf2, #ffffff);
  box-shadow: 0 14rpx 40rpx rgba(249, 115, 22, 0.08);
}

.metric-value {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--ink-dark);
}

.metric-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-medium);
}

.section {
  margin-top: 42rpx;
}

.signed-section {
  margin-top: 34rpx;
}

.signed-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.signed-card {
  min-height: 220rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ffffff, #f8fafc);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.08);
}

.signed-card.warm {
  background: linear-gradient(135deg, #fff7ed, #ffffff);
}

.signed-label {
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: #f97316;
}

.signed-title {
  margin-top: 22rpx;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
  color: var(--ink-dark);
}

.signed-sub {
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: var(--ink-medium);
}

.loading-card {
  margin-top: 24rpx;
}

/* ========== 精选课程：三列轻量卡片 ========== */
.curated-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.curated-card {
  border-radius: 8rpx;
  overflow: hidden;
  border: 2rpx solid #dcd7c9;
  background: #ffffff;
  transition: all 0.2s ease;
}

.curated-card:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.curated-cover {
  position: relative;
  height: 160rpx;
  overflow: hidden;
  background: #2c3e50;
}

.curated-img {
  width: 100%;
  height: 100%;
}

.curated-tag {
  position: absolute;
  bottom: 10rpx;
  left: 10rpx;
  padding: 4rpx 12rpx;
  background: rgba(44,62,80,0.8);
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 4rpx;
}

.curated-body {
  padding: 16rpx;
}

.curated-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ink-dark);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  min-height: 68rpx;
}

.curated-footer {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.curated-price {
  font-size: 26rpx;
  font-weight: 700;
  color: #c0392b;
  font-family: "Times New Roman", serif;
}

.curated-stock {
  font-size: 18rpx;
  color: var(--ink-light);
}

/* 查看全部 */
.curated-more {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  border: 2rpx dashed #dcd7c9;
  color: var(--ink-medium);
  font-size: 26rpx;
  background: #ffffff;
  transition: all 0.2s ease;
}

.curated-more:active {
  background: #f8fafc;
  color: var(--ink-dark);
  border-color: #2c3e50;
}

.curated-more-arrow {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 12rpx solid var(--ink-medium);
}

.editorial-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ========== 第一条：大图主推 ========== */
.edit-hero {
  display: flex;
  border-radius: 8rpx;
  overflow: hidden;
  border: 2rpx solid #dcd7c9;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  transition: all 0.2s ease;
}

.edit-hero:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.edit-hero-cover {
  position: relative;
  width: 300rpx;
  min-height: 280rpx;
  flex-shrink: 0;
  overflow: hidden;
  background: #2c3e50;
}

.edit-hero-img {
  width: 100%;
  height: 100%;
}

.edit-hero-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 4rpx 14rpx;
  background: #c0392b;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  font-family: "Times New Roman", serif;
  letter-spacing: 2rpx;
  border-radius: 2rpx;
}

.edit-hero-body {
  flex: 1;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background-image: radial-gradient(#f5f3ef 1px, transparent 0);
  background-size: 20rpx 20rpx;
}

.edit-hero-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-dark);
  line-height: 1.4;
}

.edit-hero-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--ink-medium);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.edit-hero-meta {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 2rpx dashed #dcd7c9;
}

.edit-teacher {
  font-size: 24rpx;
  color: #2c3e50;
  font-weight: 500;
}

.edit-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #c0392b;
  font-family: "Times New Roman", serif;
}

/* ========== 中间段：双列卡片 ========== */
.edit-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.edit-card {
  border-radius: 8rpx;
  overflow: hidden;
  border: 2rpx solid #dcd7c9;
  background: #ffffff;
  transition: all 0.2s ease;
}

.edit-card:active {
  transform: scale(0.97);
}

.edit-card-cover {
  position: relative;
  height: 180rpx;
  overflow: hidden;
  background: #2c3e50;
  background-image: radial-gradient(rgba(255,255,255,0.08) 1px, transparent 0);
  background-size: 16rpx 16rpx;
}

.edit-card-img {
  width: 100%;
  height: 100%;
}

.edit-card-rank {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(44,62,80,0.85);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  font-family: "Times New Roman", serif;
}

.edit-card-body {
  padding: 18rpx;
}

.edit-card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink-dark);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.edit-card-meta {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--ink-medium);
}

/* ========== 尾部段：紧凑列表 ========== */
.edit-compact {
  border-radius: 8rpx;
  overflow: hidden;
  border: 2rpx solid #dcd7c9;
  background: #ffffff;
}

.edit-compact-item {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.edit-compact-item:last-child {
  border-bottom: none;
}

.edit-compact-item:active {
  background: #f8fafc;
}

.edit-compact-rank {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 8rpx;
  background: #2c3e50;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  font-family: "Times New Roman", serif;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.edit-compact-info {
  flex: 1;
  min-width: 0;
}

.edit-compact-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--ink-dark);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-compact-meta {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--ink-light);
}

.edit-compact-price {
  flex-shrink: 0;
  margin-left: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #c0392b;
  font-family: "Times New Roman", serif;
}
