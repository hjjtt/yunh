.chapter-edit {
  padding: 32rpx;
}

.edit-header {
  margin-bottom: 28rpx;
}

.edit-eyebrow {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: var(--ink-light);
  font-family: "Times New Roman", serif;
}

.edit-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-dark);
  margin-top: 6rpx;
}

.form-section {
  padding: 32rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ink-dark);
  margin-bottom: 12rpx;
}

.form-input {
  background: var(--primary-light);
  border: 1rpx solid var(--line);
  border-radius: 4rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-group.half {
  flex: 1;
}

.section {
  margin-top: 36rpx;
}

.video-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.video-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx 20rpx 32rpx;
}

.video-info {
  flex: 1;
}

.video-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--ink-dark);
}

.video-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--ink-medium);
}

.video-delete {
  padding: 10rpx 20rpx;
  color: var(--accent);
  font-size: 24rpx;
  font-weight: 500;
}

.video-delete:active {
  opacity: 0.7;
}

.add-video-btn {
  margin-top: 12rpx;
}

.video-form {
  margin-top: 20rpx;
  padding: 28rpx;
}
