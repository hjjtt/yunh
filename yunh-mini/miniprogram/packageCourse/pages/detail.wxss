.detail-page {
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.detail-loading {
  margin-top: 32rpx;
}

.detail-hero {
  display: flex;
  gap: 16rpx;
  width: 100%;
  overflow: visible;
  align-items: start;
  margin-bottom: 24rpx;
}

.hero-main,
.hero-price-panel {
  min-height: 360rpx;
  width: 100%;
  box-sizing: border-box;
}

.card-dark.hero-main {
  background: #2c3e50;
  padding: 32rpx;
  color: #fff;
  display: block;
  min-height: 360rpx;
  flex: 1.2;
  width: 0;
  z-index: 10;
}

.detail-topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-serial {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  opacity: 0.72;
}

.detail-title {
  margin-top: 22rpx;
  max-width: 560rpx;
}

.detail-subtitle {
  max-width: 560rpx;
  color: rgba(255, 255, 255, 0.78);
}

.summary {
  margin-top: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
}

.hero-badges {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.hero-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  font-size: 22rpx;
  color: #fffaf6;
}

.hero-price-panel {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-self: start;
  flex: 1;
  width: 0;
}

.hero-price-label {
  font-size: 22rpx;
  letter-spacing: 5rpx;
  text-transform: uppercase;
}

.price-block {
  display: flex;
  align-items: baseline;
  margin-top: 24rpx;
  color: var(--accent);
}

.price-prefix {
  font-size: 34rpx;
  font-weight: 700;
  font-family: "Times New Roman", serif;
}

.price-text-display {
  margin-left: 8rpx;
  font-size: 58rpx;
  line-height: 1;
  font-weight: 700;
  font-family: "Times New Roman", serif;
}

.hero-stock {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--ink-dark);
}

.hero-price-note {
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--ink-medium);
}

.mini-buy-button {
  margin-top: 16rpx;
  height: 84rpx;
  display: block;
  align-items: center;
  justify-content: center;
  border-radius: 4rpx;
  background: var(--accent);
  color: #ffffff;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-align: center;
  font-family: "Times New Roman", serif;
}

.empty-panel {
  margin-top: 4rpx;
  padding: 16rpx;
  border: 1rpx dashed rgba(44, 62, 80, 0.18);
  background: linear-gradient(135deg, #fffdf9, #f7efe4);
  min-height: 80rpx;
}

.empty-panel-title {
  font-size: 28rpx;
  color: var(--ink-dark);
  font-weight: 700;
}

.empty-panel-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.8;
  color: var(--ink-medium);
}

.mini-buy-button:active {
  transform: translateY(2rpx);
  background: var(--accent);
}

.detail-stats {
  margin-top: 24rpx;
}

.stat-card {
  border-left-color: var(--accent);
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-dark);
  font-family: "Times New Roman", serif;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-medium);
}

.detail-card {
  margin-top: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 16rpx;
}

.section-kicker {
  font-size: 20rpx;
  color: var(--ink-medium);
  text-align: right;
}

.purchase-card {
  background: linear-gradient(135deg, #fffdf9, #f6efe5);
}

.purchase-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.purchase-metric {
  padding: 22rpx;
  border: 1rpx solid rgba(44, 62, 80, 0.12);
  background: rgba(255, 255, 255, 0.78);
}

.purchase-label {
  font-size: 20rpx;
  color: var(--ink-medium);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.purchase-value {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--ink-dark);
  line-height: 1.5;
}

.timeline {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.timeline-item {
  display: flex;
  gap: 18rpx;
}

.timeline-dot {
  width: 18rpx;
  height: 18rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: var(--accent);
}

.timeline-content {
  flex: 1;
  padding-bottom: 18rpx;
  border-bottom: 2rpx solid #e8dfd1;
}

.timeline-title {
  font-size: 28rpx;
  color: var(--ink-dark);
}

.timeline-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-medium);
}

.preview-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 12rpx;
}

.preview-card {
  padding: 24rpx;
  border-radius: 4rpx;
  background: var(--primary);
  color: #ffffff;
  border-left: 4rpx solid var(--accent);
}

.preview-tag {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.66);
  text-transform: uppercase;
}

.preview-title {
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.preview-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.76);
}

.video-list {
  margin-top: 24rpx;
}

.video-empty {
  padding: 8rpx 0 4rpx;
}

.video-item {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 22rpx 0;
  border-bottom: 2rpx solid #ebe3d8;
}

.video-copy {
  flex: 1;
}

.video-title {
  font-size: 28rpx;
  color: var(--ink-dark);
}

.video-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-medium);
}

.video-duration {
  font-size: 22rpx;
  color: var(--accent);
  white-space: nowrap;
}

.purchase-ribbon {
  position: fixed;
  left: 48rpx;
  right: 48rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  padding: 24rpx 28rpx;
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: center;
  background: rgba(44, 62, 80, 0.96);
  color: #ffffff;
  border-left: 6rpx solid var(--accent);
  box-shadow: 0 18rpx 36rpx rgba(44, 62, 80, 0.18);
}

.purchase-ribbon-copy {
  min-width: 0;
}

.purchase-ribbon-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.68);
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.purchase-ribbon-title {
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.4;
}

.purchase-ribbon-actions {
  width: 320rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.purchase-secondary,
.purchase-primary {
  height: 74rpx;
  font-size: 24rpx;
}

@media (max-width: 720rpx) {
  .detail-hero,
  .preview-grid,
  .purchase-grid {
    grid-template-columns: 1fr;
  }

  .purchase-ribbon {
    left: 24rpx;
    right: 24rpx;
    flex-direction: column;
    align-items: stretch;
  }

  .purchase-ribbon-actions {
    width: 100%;
  }
}


/* ========== Learning Roadmap Card ========== */
.roadmap-card {
  margin-top: 24rpx;
  background-image: radial-gradient(#f5f3ef 1px, transparent 0);
  background-size: 20rpx 20rpx;
}
.roadmap-steps {
  margin-top: 20rpx;
}
.roadmap-step {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx dashed var(--line);
}
.roadmap-step:last-child {
  border-bottom: none;
}
.step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 4rpx;
  background: var(--primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  font-family: "Times New Roman", serif;
  flex-shrink: 0;
}
.step-content {
  flex: 1;
}
.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-dark);
  margin-bottom: 6rpx;
}
.step-desc {
  font-size: 24rpx;
  color: var(--ink-medium);
  line-height: 1.5;
}

/* Course Benefits Card */
.benefit-card {
  margin-top: 24rpx;
  background-image: radial-gradient(#f5f3ef 1px, transparent 0);
  background-size: 20rpx 20rpx;
}
.benefit-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 20rpx;
}
.benefit-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  border-radius: 4rpx;
  background: var(--primary-light);
  border: 1rpx solid var(--line);
  transition: all 0.2s ease;
}
.benefit-item:active {
  transform: scale(0.98);
  background: var(--accent-light);
}
.benefit-icon {
  font-size: 36rpx;
}
.benefit-text {
  font-size: 26rpx;
  color: var(--ink-dark);
  font-weight: 500;
}

/* Study Guarantee Card: Vintage Ticket Style */
.guarantee-card {
  margin-top: 24rpx;
  background: var(--accent-light);
  border-left: 8rpx solid var(--accent);
  background-image: radial-gradient(rgba(192,57,43,0.05) 1px, transparent 0);
  background-size: 16rpx 16rpx;
  border: 1rpx dashed var(--accent);
}
.guarantee-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.guarantee-tag {
  padding: 8rpx 16rpx;
  border-radius: 2rpx;
  background: var(--accent);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  font-family: "Times New Roman", serif;
  letter-spacing: 2rpx;
  flex-shrink: 0;
}
.guarantee-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--ink-dark);
  line-height: 1.6;
}

/* ========== Dynamic Price Card Effects ========== */
.dynamic-price-card {
  animation: cardFadeIn 0.6s ease-out forwards;
  border: 1rpx solid var(--accent);
  position: relative;
  overflow: hidden;
}
.dynamic-price-card::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 2rpx;
  background: repeating-linear-gradient(90deg, var(--accent), var(--accent) 8rpx, transparent 8rpx, transparent 16rpx);
  animation: borderMove 10s linear infinite;
}
.dynamic-price-card::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 2rpx;
  background: repeating-linear-gradient(90deg, var(--accent), var(--accent) 8rpx, transparent 8rpx, transparent 16rpx);
  animation: borderMove 10s linear infinite reverse;
}

.price-animate {
  animation: priceJump 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards 0.3s;
  transform: translateY(20rpx);
  opacity: 0;
}

.stock-flash {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.stock-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--accent);
  animation: flash 1.5s ease-in-out infinite;
}

.pulse-button {
  animation: pulse 2s ease-in-out infinite;
}
.pulse-button:active {
  transform: scale(0.96);
  transition: transform 0.1s ease;
}

/* Animations */
@keyframes cardFadeIn {
  from {
    transform: translateX(20rpx);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}
@keyframes borderMove {
  from {
    background-position: 0 0;
  }
  to {
    background-position: 320rpx 0;
  }
}
@keyframes priceJump {
  0% {
    transform: translateY(20rpx);
    opacity: 0;
  }
  60% {
    transform: translateY(-6rpx);
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}
@keyframes flash {
  0%, 100% {
    opacity: 1;
    box-shadow: 0 0 8rpx var(--accent);
  }
  50% {
    opacity: 0.4;
    box-shadow: 0 0 0rpx var(--accent);
  }
}
@keyframes pulse {
  0%, 100% {
    box-shadow: 0 0 0rpx rgba(192,57,43, 0.3);
  }
  50% {
    box-shadow: 0 0 12rpx rgba(192,57,43, 0.6);
  }
}
