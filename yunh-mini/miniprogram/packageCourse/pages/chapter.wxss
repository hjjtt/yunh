.chapter-list {
  margin-top: 24rpx;
}

.chapter-item {
  border-bottom: 2rpx solid var(--line);
  overflow: hidden;
}

/* 章节头部 */
.chapter-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.chapter-info {
  flex: 1;
}

.chapter-title {
  font-size: 28rpx;
  color: var(--ink-dark);
  font-weight: 500;
}

.chapter-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--ink-medium);
}

/* 展开/收起箭头 */
.chapter-arrow {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-left: 16rpx solid var(--ink-light);
  transition: transform 0.3s ease;
  transform: rotate(0deg);
}

.chapter-arrow.expanded {
  transform: rotate(90deg);
}

/* 视频子列表 */
.video-list {
  padding: 0 0 16rpx 24rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.video-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid var(--line);
}

.video-item:last-child {
  border-bottom: none;
}

.video-icon {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 16rpx solid #3b82f6;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.video-info {
  flex: 1;
}

.video-title {
  font-size: 26rpx;
  color: var(--ink-dark);
}

.video-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--ink-light);
}

/* 无视频提示 */
.no-video {
  padding: 20rpx 24rpx;
  font-size: 24rpx;
  color: var(--ink-light);
}
