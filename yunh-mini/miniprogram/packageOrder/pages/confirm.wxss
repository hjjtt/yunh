.checkout-page {
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.checkout-hero {
  display: grid;
  grid-template-columns: 1.4fr 0.9fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.checkout-main,
.checkout-side {
  min-height: 100%;
}

.checkout-title {
  margin-top: 20rpx;
}

.checkout-subtitle {
  color: rgba(255, 255, 255, 0.78);
}

.checkout-price-line {
  display: flex;
  align-items: baseline;
  margin-top: 26rpx;
}

.checkout-price-prefix {
  font-size: 34rpx;
  font-weight: 700;
  font-family: "Times New Roman", serif;
}

.checkout-price-value {
  margin-left: 8rpx;
  font-size: 66rpx;
  line-height: 1;
  font-weight: 700;
  font-family: "Times New Roman", serif;
}

.checkout-side-label {
  font-size: 20rpx;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

.checkout-side-value {
  margin-top: 18rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  font-family: "Times New Roman", serif;
}

.checkout-side-note {
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--ink-medium);
}

.checkout-card {
  margin-top: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 16rpx;
}

.section-kicker {
  font-size: 20rpx;
  color: var(--ink-medium);
}

.order-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.order-metric {
  padding: 22rpx;
  background: linear-gradient(135deg, #fffdf9, #f7efe4);
  border: 1rpx solid rgba(44, 62, 80, 0.12);
}

.order-label {
  font-size: 20rpx;
  color: var(--ink-medium);
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.order-value {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--ink-dark);
}

.pay-type-list {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.pay-type-item {
  padding: 26rpx;
  border: 2rpx solid rgba(44, 62, 80, 0.12);
  background: #fffdfa;
  transition: all 0.2s ease;
}

.pay-type-item.active {
  background: #2c3e50 !important;
  border-color: #e74c3c !important;
}

.pay-type-name {
  font-size: 28rpx;
  color: var(--ink-dark);
  font-weight: 700;
}

.pay-type-caption {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--ink-medium);
  line-height: 1.6;
}

.pay-type-item.active .pay-type-name,
.pay-type-item.active .pay-type-caption {
  color: #ffffff;
}

.checkout-footer {
  position: fixed;
  left: 48rpx;
  right: 48rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  background: rgba(248, 245, 240, 0.98);
  border-left: 6rpx solid var(--accent);
  box-shadow: 0 18rpx 36rpx rgba(44, 62, 80, 0.12);
}

.checkout-footer-copy {
  min-width: 0;
}

.checkout-footer-label {
  font-size: 20rpx;
  color: var(--ink-medium);
  text-transform: uppercase;
  letter-spacing: 3rpx;
}

.checkout-footer-amount {
  margin-top: 8rpx;
  font-size: 40rpx;
  color: var(--primary);
  font-family: "Times New Roman", serif;
  font-weight: 700;
}

.checkout-submit {
  width: 300rpx;
  flex-shrink: 0;
}

@media (max-width: 720rpx) {
  .checkout-hero,
  .order-grid,
  .pay-type-list {
    grid-template-columns: 1fr;
  }

  .checkout-footer {
    left: 24rpx;
    right: 24rpx;
    flex-direction: column;
    align-items: stretch;
  }

  .checkout-submit {
    width: 100%;
  }
}

/* ========== Fix Display Issues ========== */
.checkout-hero {
  display: flex !important;
  gap: 16rpx !important;
  width: 100% !important;
  overflow: visible !important;
}
.checkout-main.card-dark {
  background: #2c3e50 !important;
  padding: 32rpx !important;
  color: #fff !important;
  display: block !important;
  min-height: 320rpx !important;
  flex: 1.4 !important;
  width: 0 !important;
  z-index: 10 !important;
}
.checkout-side {
  flex: 0.9 !important;
  width: 0 !important;
  min-height: 320rpx !important;
}
