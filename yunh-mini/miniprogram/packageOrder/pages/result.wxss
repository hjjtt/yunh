.result-hero {
  display: flex !important;
  gap: 16rpx !important;
  width: 100% !important;
  overflow: visible !important;
  margin-bottom: 24rpx;
}

.result-hero-main,
.result-hero-side {
  min-height: 240rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

.result-hero-main {
  background: #2c3e50 !important;
  color: #ffffff !important;
  flex: 1.2 !important;
  width: 0 !important;
  z-index: 10 !important;
  border-radius: 4rpx;
}

.result-hero-side {
  background: #fffdf9 !important;
  flex: 0.8 !important;
  width: 0 !important;
  border: 1rpx solid rgba(44, 62, 80, 0.12);
  border-radius: 4rpx;
}

.result-side-label {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #e74c3c;
  text-transform: uppercase;
}

.result-side-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--ink-medium);
}

.result-status-text {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-top: 24rpx;
  font-family: "Times New Roman", serif;
}

.result-card {
  margin-bottom: 24rpx;
  text-align: left;
  background: linear-gradient(135deg, #fffdf9, #f7efe4);
  border: 1rpx solid rgba(44, 62, 80, 0.12);
  border-radius: 4rpx;
}

.result-meta {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid rgba(44, 62, 80, 0.08);
}

.meta-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.meta-label {
  font-size: 24rpx;
  color: #7c8a96;
}

.meta-value {
  font-size: 24rpx;
  color: #2c3e50;
  font-weight: 500;
}

.meta-price {
  color: #e74c3c;
  font-weight: 700;
  font-size: 28rpx;
}

.status-strip {
  margin-bottom: 18rpx;
  padding: 18rpx 24rpx;
  border-radius: 4rpx;
  background: #fff7ed;
  border: 1rpx dashed #e74c3c;
  color: #9a3412;
  font-size: 22rpx;
  text-align: center;
}

.result-button {
  margin-top: 18rpx;
}

.pill {
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  color: #fffaf9;
  font-family: "Times New Roman", serif;
}

.page-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  line-height: 1.6;
}

.sim-pay-card {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #fffdf9, #f7efe4);
  border: 1rpx solid rgba(44, 62, 80, 0.12);
  border-radius: 4rpx;
}

.sim-pay-desc {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #7c8a96;
}

.sim-pay-amount {
  margin-top: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #2c3e50;
  border-radius: 4rpx;
}

.sim-pay-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.78);
}

.sim-pay-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #e74c3c;
  font-family: "Times New Roman", serif;
}

.sim-pay-btn {
  margin-top: 24rpx;
}

.result-nav-card {
  margin-top: 24rpx;
  text-align: center;
  background: linear-gradient(135deg, #fffdf9, #f7efe4);
  border: 1rpx solid rgba(44, 62, 80, 0.12);
  border-radius: 4rpx;
  padding: 48rpx 32rpx;
}

.result-nav-icon {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 50%;
  background: #27ae60;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
  margin: 0 auto;
}

.result-nav-icon.fail {
  background: #e74c3c;
}

.result-nav-title {
  margin-top: 24rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #2c3e50;
}

.result-nav-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7c8a96;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 16rpx;
}

.section-kicker {
  font-size: 20rpx;
  color: #7c8a96;
  text-align: right;
}
