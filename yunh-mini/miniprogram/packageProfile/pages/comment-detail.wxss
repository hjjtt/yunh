.comment-detail {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* 评论主体 */
.detail-main {
  margin-bottom: 24rpx;
}

.detail-content {
  font-size: 32rpx;
  color: var(--ink-dark);
  line-height: 1.8;
  word-break: break-word;
}

.detail-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed var(--line);
}

.meta-course {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 600;
}

.meta-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 22rpx;
  color: var(--ink-light);
}

.meta-likes {
  color: var(--accent);
}

/* 回复区 */
.reply-section {
  margin-bottom: 24rpx;
}

.reply-header {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-dark);
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.reply-input {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--ink-dark);
  background: var(--paper);
  border: 1rpx solid var(--line);
  border-radius: 4rpx;
}

.reply-btn {
  margin-top: 20rpx;
  text-align: center;
  padding: 22rpx;
  background: var(--primary);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 4rpx;
  letter-spacing: 2rpx;
}

.reply-btn:active {
  opacity: 0.8;
}

.reply-btn.disabled {
  background: var(--ink-light);
}

/* 删除 */
.detail-bottom {
  padding: 0 32rpx;
}

.delete-btn {
  text-align: center;
  padding: 22rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--accent);
  background: #fff5f5;
  border: 2rpx solid #fecaca;
  border-radius: 4rpx;
}

.delete-btn:active {
  opacity: 0.7;
}
