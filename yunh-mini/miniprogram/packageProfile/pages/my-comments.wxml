<view class="page my-comments">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-eyebrow">COMMENTS</view>
    <view class="page-title">课程评论</view>
  </view>

  <!-- 加载中 -->
  <view class="loading-hint" wx:if="{{loading}}">加载中...</view>

  <!-- 空态 -->
  <view class="empty-state" wx:if="{{!loading && !comments.length}}">
    <view class="empty-icon-wrap">
      <view class="empty-comment"></view>
    </view>
    <view class="empty-title">暂无评论</view>
    <view class="empty-desc">去课程详情页发表评论吧</view>
  </view>

  <!-- 评论列表 -->
  <view class="comment-list" wx:if="{{!loading && comments.length}}">
    <view class="comment-card card" wx:for="{{comments}}" wx:key="id" bindtap="handleView" data-index="{{index}}">
      <view class="comment-content">{{item.content}}</view>
      <view class="comment-foot">
        <view class="comment-course">{{item.courseName}}</view>
        <view class="comment-actions">
          <view class="comment-time" wx:if="{{item.createTime}}">{{item.createTime}}</view>
          <view class="comment-likes">♥ {{item.likeCount || 0}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 新建评论按钮 -->
  <view class="fab" bindtap="goCreate">
    <text class="fab-plus">+</text>
    <text class="fab-text">写评论</text>
  </view>
</view>
