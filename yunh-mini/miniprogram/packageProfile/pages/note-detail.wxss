.note-detail {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* 头部 */
.detail-header {
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--ink-dark);
  line-height: 1.4;
}

.detail-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 16rpx;
}

.detail-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.detail-badge.public {
  background: #ecfdf5;
  color: #059669;
}

.detail-badge.private {
  background: #f1f5f9;
  color: var(--ink-medium);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--ink-light);
}

.meta-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #cbd5e1;
}

/* 内容区 */
.detail-body {
  padding: 32rpx !important;
  margin-bottom: 20rpx;
}

.content-text {
  font-size: 30rpx;
  color: var(--ink-dark);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-word;
}

/* 信息卡 */
.detail-info {
  padding: 0 !important;
  margin-bottom: 48rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: var(--ink-light);
}

.info-value {
  font-size: 26rpx;
  color: var(--ink-dark);
  font-weight: 500;
}

/* 删除按钮 */
.detail-actions {
  padding: 0 32rpx;
}

.delete-btn {
  text-align: center;
  padding: 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #c0392b;
  background: #fff5f5;
  border: 2rpx solid #fecaca;
}

.delete-btn:active {
  opacity: 0.7;
}

.delete-btn.disabled {
  color: var(--ink-light);
  background: #f1f5f9;
  border-color: var(--line);
}
