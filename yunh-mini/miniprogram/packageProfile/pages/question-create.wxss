.question-create {
  padding: 32rpx;
  padding-bottom: calc(252rpx + env(safe-area-inset-bottom));
}

.create-header {
  margin-bottom: 28rpx;
}

.create-eyebrow {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: var(--ink-light);
  font-family: "Times New Roman", serif;
}

.create-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-dark);
  margin-top: 6rpx;
}

/* 表单卡片 */
.form-card {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink-dark);
  margin-bottom: 16rpx;
}

.form-empty {
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: var(--ink-light);
}

/* 选择器 */
.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--paper);
  border: 1rpx solid var(--line);
  border-radius: 4rpx;
}

.picker-text {
  font-size: 28rpx;
  color: var(--ink-dark);
}

.picker-arrow {
  width: 0;
  height: 0;
  border-top: 10rpx solid var(--ink-light);
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
}

/* 输入框 */
.form-input {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--ink-dark);
  background: var(--paper);
  border: 1rpx solid var(--line);
  border-radius: 4rpx;
  vertical-align: middle;
}

.form-textarea {
  width: 100%;
  height: 280rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--ink-dark);
  background: var(--paper);
  border: 1rpx solid var(--line);
  border-radius: 4rpx;
}

.form-count {
  text-align: right;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-light);
}

.submit-panel {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 30;
}

.submit-panel-inner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 24rpx 22rpx 28rpx;
  background: rgba(248, 245, 240, 0.96);
  border: 1rpx solid rgba(220, 215, 201, 0.92);
  border-left: 8rpx solid var(--accent);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 42rpx rgba(45, 52, 54, 0.14);
  backdrop-filter: blur(18rpx);
}

.submit-copy {
  flex: 1;
  min-width: 0;
}

.submit-copy-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(192, 57, 43, 0.1);
  color: var(--accent);
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  font-family: "Times New Roman", serif;
}

.submit-copy-title {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink-dark);
  line-height: 1.2;
}

.submit-copy-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--ink-medium);
  line-height: 1.5;
}

.submit-button-shell {
  flex-shrink: 0;
}

.submit-btn {
  min-width: 228rpx;
  height: 96rpx;
  padding: 0 28rpx 0 34rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #c0392b 0%, #9f2d22 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(192, 57, 43, 0.32);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
}

.submit-btn:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 6rpx 16rpx rgba(192, 57, 43, 0.22);
}

.submit-btn.disabled {
  background: linear-gradient(135deg, #b2bec3 0%, #95a5a6 100%);
  box-shadow: none;
  border-color: transparent;
  color: rgba(255, 255, 255, 0.92);
}

.submit-btn-text {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.submit-btn-icon {
  margin-left: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}
