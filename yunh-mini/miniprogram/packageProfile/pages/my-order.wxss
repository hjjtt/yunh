.order-hero {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.order-hero-main,
.order-hero-side {
  padding: 28rpx;
  border-radius: 30rpx;
}

.order-hero-main {
  background: linear-gradient(135deg, #111827, #0f766e);
  color: #ffffff;
}

.order-hero-side {
  background: linear-gradient(135deg, #fff7ed, #ffffff);
}

.order-side-label {
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: #f97316;
}

.order-side-value {
  margin-top: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.6;
  color: #7c2d12;
}

.order-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.order-stat-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fffaf2, #ffffff);
  box-shadow: 0 14rpx 34rpx rgba(249, 115, 22, 0.08);
}

.order-stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.order-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.order-card {
  background: linear-gradient(135deg, #ffffff, #f8fafc);
}

.order-list {
  margin-top: 8rpx;
}

.order-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #e2e8f0;
}

.order-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.order-title {
  flex: 1;
  font-size: 28rpx;
  color: #0f172a;
}

.order-status {
  white-space: nowrap;
  color: #0f766e;
  font-size: 22rpx;
}

.order-sub {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
}

.order-time {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 22rpx;
}
