.question-detail {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* 问题主体 */
.question-main {
  margin-bottom: 28rpx;
}

.q-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-dark);
  line-height: 1.4;
}

.q-content {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: var(--ink-medium);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-word;
}

.q-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 2rpx dashed var(--line);
}

.q-course {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 600;
}

.q-stats {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: var(--ink-light);
}

.q-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-light);
}

/* 回答区 */
.answers-section {
  margin-bottom: 24rpx;
}

.answers-section {
  margin-bottom: 24rpx;
}

.answer-card {
  margin-bottom: 16rpx;
}

.answer-content {
  font-size: 28rpx;
  color: var(--ink-dark);
  line-height: 1.7;
  word-break: break-word;
}

.answer-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--line);
}

.answer-meta {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: var(--ink-light);
}

.answer-likes {
  color: var(--accent);
}

.accepted-badge {
  font-size: 22rpx;
  color: #059669;
  font-weight: 600;
  background: #ecfdf5;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.accept-btn {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 600;
  padding: 4rpx 16rpx;
  border: 1rpx solid var(--primary);
  border-radius: 4rpx;
}

.accept-btn:active {
  background: var(--primary-light);
}

.no-answers {
  text-align: center;
  padding: 40rpx 0;
  color: var(--ink-light);
  font-size: 26rpx;
}

.no-answers-icon {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--primary-light);
  border: 2rpx solid var(--line);
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  margin: 0 auto 16rpx;
  font-family: "Times New Roman", serif;
}

/* 回答输入 */
.answer-form {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink-dark);
  margin-bottom: 16rpx;
}

.answer-input {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--ink-dark);
  background: var(--paper);
  border: 1rpx solid var(--line);
  border-radius: 4rpx;
}

.answer-submit {
  margin-top: 20rpx;
  text-align: center;
  padding: 22rpx;
  background: var(--primary);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 4rpx;
  letter-spacing: 2rpx;
}

.answer-submit:active {
  opacity: 0.8;
}

.answer-submit.disabled {
  background: var(--ink-light);
}

/* 删除 */
.detail-bottom {
  padding: 0;
}

.delete-btn {
  text-align: center;
  padding: 22rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--accent);
  background: #fff5f5;
  border: 2rpx solid #fecaca;
  border-radius: 4rpx;
}

.delete-btn:active {
  opacity: 0.7;
}
