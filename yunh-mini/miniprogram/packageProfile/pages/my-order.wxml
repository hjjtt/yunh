<view class="page">
  <view class="order-hero">
    <view class="order-hero-main">
      <view class="pill">Order Archive</view>
      <view class="page-title">我的订单</view>
      <view class="page-subtitle">这里展示的是订单表里已经落库的真实记录，状态会跟着支付链路一起变化。</view>
    </view>
    <view class="order-hero-side">
      <view class="order-side-label">订单视图</view>
      <view class="order-side-value">时间倒序 / 状态同步</view>
    </view>
  </view>

  <view class="order-stats" wx:if="{{stats.length}}">
    <view class="order-stat-card" wx:for="{{stats}}" wx:key="label">
      <view class="order-stat-value">{{item.value}}</view>
      <view class="order-stat-label">{{item.label}}</view>
    </view>
  </view>

  <view class="card order-card">
    <view wx:if="{{loading}}" class="empty-text">订单加载中...</view>
    <view wx:elif="{{!orderList.length}}" class="empty-text">暂无订单记录</view>
    <view wx:else class="order-list">
      <view class="order-item" wx:for="{{orderList}}" wx:key="id">
        <view class="order-head">
          <view class="order-title">{{item.courseName}}</view>
          <view class="order-status">{{item.statusText}}</view>
        </view>
        <view class="order-sub">{{item.orderNo}}</view>
        <view class="order-sub">{{item.userName}} · {{item.amountText}}</view>
        <view class="order-time">{{item.createTimeText}}</view>
      </view>
    </view>
  </view>
</view>
