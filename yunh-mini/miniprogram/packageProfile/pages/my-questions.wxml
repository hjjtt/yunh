<view class="page my-questions">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-eyebrow">Q &amp; A</view>
    <view class="page-title">课程问答</view>
  </view>

  <!-- 加载中 -->
  <view class="loading-hint" wx:if="{{loading}}">加载中...</view>

  <!-- 空态 -->
  <view class="empty-state" wx:if="{{!loading && !questions.length}}">
    <view class="empty-icon-wrap">
      <view class="empty-question">?</view>
    </view>
    <view class="empty-title">暂无问答</view>
    <view class="empty-desc">在课程学习中提出你的疑问吧</view>
  </view>

  <!-- 问题列表 -->
  <view class="question-list" wx:if="{{!loading && questions.length}}">
    <view class="question-card card" wx:for="{{questions}}" wx:key="id" bindtap="handleView" data-index="{{index}}">
      <view class="question-head">
        <view class="question-title">{{item.title || '无标题'}}</view>
      </view>
      <view class="question-body" wx:if="{{item.content}}">{{item.content}}</view>
      <view class="question-foot">
        <view class="question-course">{{item.courseName}}</view>
        <view class="question-actions">
          <view class="question-answers">{{item.answerCount || 0}} 回答</view>
          <view class="question-views">{{item.viewCount || 0}} 浏览</view>
          <view class="question-delete" data-id="{{item.id}}" catchtap="handleDelete">删除</view>
        </view>
      </view>
      <view class="question-time" wx:if="{{item.createTime}}">{{item.createTime}}</view>
    </view>
  </view>

  <!-- 新建提问按钮 -->
  <view class="fab" bindtap="goCreate">
    <text class="fab-plus">+</text>
    <text class="fab-text">去提问</text>
  </view>
</view>
