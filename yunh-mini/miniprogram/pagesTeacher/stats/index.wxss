.teacher-stats {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom) + 120rpx);
}

/* ===== 标题 ===== */
.stats-header {
  margin-bottom: 24rpx;
}

.stats-eyebrow {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: var(--ink-light);
  font-family: "Times New Roman", serif;
}

.stats-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-dark);
  margin-top: 6rpx;
}

/* ===== 日期选择 ===== */
.date-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.date-pill {
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--ink-medium);
  background: #ffffff;
  border: 1rpx solid var(--line);
}

.date-pill.active {
  background: var(--primary);
  color: #ffffff;
  border-color: var(--primary);
}

/* ===== 汇总卡片 ===== */
.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-bottom: 36rpx;
}

.summary-card {
  background: #ffffff;
  border-radius: 4rpx;
  padding: 28rpx;
  box-shadow: var(--paper-shadow);
  border: 1rpx solid var(--line);
  border-left: 6rpx solid var(--primary);
  animation: slideUp 0.4s ease forwards;
  opacity: 0;
}

.summary-card:nth-child(1) { animation-delay: 0.05s; }
.summary-card:nth-child(2) { animation-delay: 0.1s; }
.summary-card:nth-child(3) { animation-delay: 0.15s; }
.summary-card:nth-child(4) { animation-delay: 0.2s; }

@keyframes slideUp {
  from { transform: translateY(16rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.summary-card.accent {
  border-left-color: var(--accent);
}

.summary-value {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--primary);
  font-family: "Times New Roman", serif;
}

.summary-card.accent .summary-value {
  color: var(--accent);
}

.summary-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--ink-medium);
}

/* ===== 课程统计 ===== */
.section {
  margin-top: 8rpx;
}

.stat-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.stat-course {
  padding: 24rpx 28rpx 24rpx 36rpx;
}

.stat-course-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.stat-course-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-dark);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stat-course-status {
  padding: 4rpx 14rpx;
  border-radius: 2rpx;
  font-size: 20rpx;
  font-weight: 600;
  margin-left: 16rpx;
}

.stat-course-status.active {
  background: #e8f5e9;
  color: #2e7d32;
}

.stat-course-status.off {
  background: #f5f5f5;
  color: #9e9e9e;
}

.stat-metrics {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.stat-metric {
  text-align: center;
  padding: 14rpx 8rpx;
  background: var(--primary-light);
  border-radius: 4rpx;
}

.stat-metric.income {
  background: var(--accent-light);
}

.metric-val {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary);
  font-family: "Times New Roman", serif;
}

.stat-metric.income .metric-val {
  color: var(--accent);
}

.metric-lbl {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--ink-medium);
}

.empty-hint {
  text-align: center;
  padding: 60rpx 32rpx;
  color: var(--ink-medium);
  font-size: 26rpx;
}

/* ===== 收入趋势图 ===== */
.chart-section {
  margin-top: 36rpx;
}

.chart-box {
  padding: 16rpx 8rpx 8rpx;
}

.trend-canvas {
  width: 100%;
  height: 400rpx;
  display: block;
}
