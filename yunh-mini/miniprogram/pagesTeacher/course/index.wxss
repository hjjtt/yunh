.teacher-course {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom) + 120rpx);
}

/* ===== 顶部 ===== */
.header {
  margin-bottom: 24rpx;
}

.header-eyebrow {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: var(--ink-light);
  font-family: "Times New Roman", serif;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-dark);
}

.create-btn {
  padding: 12rpx 28rpx;
  background: var(--accent);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 4rpx;
  letter-spacing: 1rpx;
}

.create-btn:active {
  background: #a93226;
}

/* ===== 搜索栏 ===== */
.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  background: #ffffff;
  border: 1rpx solid var(--line);
  border-radius: 4rpx;
  padding: 18rpx 24rpx;
  font-size: 26rpx;
  box-shadow: var(--press-shadow);
}

/* ===== 筛选栏 ===== */
.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-pill {
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--ink-medium);
  background: #ffffff;
  border: 1rpx solid var(--line);
  transition: all 0.2s ease;
}

.filter-pill.active {
  background: var(--primary);
  color: #ffffff;
  border-color: var(--primary);
}

/* ===== 统计面板 ===== */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #ffffff;
  border-radius: 4rpx;
  padding: 24rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid var(--line);
  box-shadow: var(--press-shadow);
}

.stats-item {
  text-align: center;
}

.stats-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  font-family: "Times New Roman", serif;
}

.stats-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--ink-medium);
}

.stats-divider {
  width: 1rpx;
  height: 50rpx;
  background: var(--line);
}

/* ===== 课程列表 ===== */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.course-card {
  padding: 0;
  overflow: hidden;
}

.card-main {
  padding: 24rpx 28rpx 24rpx 36rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-dark);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-status {
  padding: 4rpx 14rpx;
  border-radius: 2rpx;
  font-size: 20rpx;
  font-weight: 600;
  margin-left: 16rpx;
}

.card-status.active {
  background: #e8f5e9;
  color: #2e7d32;
}

.card-status.off {
  background: #f5f5f5;
  color: #9e9e9e;
}

.card-meta {
  margin-top: 14rpx;
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: var(--ink-medium);
}

.meta-price {
  color: var(--accent);
  font-weight: 700;
  font-family: "Times New Roman", serif;
}

.meta-time {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--ink-light);
}

.card-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--ink-medium);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-actions {
  display: flex;
  border-top: 2rpx dashed var(--line);
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn.edit {
  color: var(--primary);
}

.action-btn.delete {
  color: var(--accent);
  border-left: 2rpx dashed var(--line);
}

.action-btn:active {
  background: var(--primary-light);
}

/* ===== 空态 ===== */
.empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--ink-dark);
  font-weight: 500;
}

.empty-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--ink-medium);
}
