.teacher-profile {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom) + 120rpx);
}

/* ===== Hero 头部卡片 ===== */
.profile-hero {
  background: linear-gradient(135deg, #2c3e50 0%, #34495e 60%, #2c3e50 100%);
  color: #ffffff;
  border-radius: 4rpx;
  padding: 48rpx 36rpx 36rpx;
  border-left: 8rpx solid var(--accent);
  box-shadow: var(--paper-shadow);
  position: relative;
  overflow: hidden;
  animation: heroSlideIn 0.5s ease forwards;
}

@keyframes heroSlideIn {
  from {
    transform: translateY(20rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

/* 右上角装饰纹理 */
.hero-decoration {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
  border: 2rpx solid rgba(255, 255, 255, 0.06);
}

.hero-decoration::after {
  content: "";
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.03);
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}

.hero-content {
  display: flex;
  align-items: center;
  gap: 28rpx;
  position: relative;
  z-index: 1;
}

/* 头像圆环 */
.avatar-ring {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent) 0%, #e74c3c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(192, 57, 43, 0.35);
  flex-shrink: 0;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  text-align: center;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 700;
  font-family: "Times New Roman", serif;
  backdrop-filter: blur(4px);
}

/* 姓名和角色 */
.hero-info {
  flex: 1;
}

.hero-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 10rpx;
  padding: 6rpx 18rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 999rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
  font-family: "Times New Roman", serif;
}

.badge-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #2ecc71;
  box-shadow: 0 0 8rpx rgba(46, 204, 113, 0.5);
}

/* 统计条 */
.hero-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: 36rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.12);
  position: relative;
  z-index: 1;
}

.hero-stat {
  text-align: center;
  flex: 1;
}

.hero-stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  font-family: "Times New Roman", serif;
  line-height: 1.2;
}

.hero-stat-lbl {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 1rpx;
}

.hero-stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.12);
}

/* ===== Sections ===== */
.section {
  margin-top: 36rpx;
}

/* ===== 快捷入口 ===== */
.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.shortcut-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 12rpx 28rpx;
  background: #ffffff;
  border-radius: 4rpx;
  border: 1rpx solid var(--line);
  box-shadow: var(--press-shadow);
  transition: all 0.2s ease;
  animation: cardSlideIn 0.4s ease forwards;
  opacity: 0;
}

.shortcut-item:nth-child(1) { animation-delay: 0.06s; }
.shortcut-item:nth-child(2) { animation-delay: 0.10s; }
.shortcut-item:nth-child(3) { animation-delay: 0.14s; }
.shortcut-item:nth-child(4) { animation-delay: 0.18s; }
.shortcut-item:nth-child(5) { animation-delay: 0.22s; }
.shortcut-item:nth-child(6) { animation-delay: 0.26s; }

@keyframes cardSlideIn {
  from {
    transform: translateY(16rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.shortcut-item:active {
  transform: translateY(2rpx);
  background: var(--primary-light);
}

.shortcut-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 图标背景色 */
.icon-manage {
  background: linear-gradient(180deg, #e7eef4 0%, #d5e2ee 100%);
  border: 2rpx solid rgba(44, 62, 80, 0.08);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.8);
}

.icon-stats {
  background: linear-gradient(180deg, #efe7d3 0%, #e4d2a8 100%);
  border: 2rpx solid rgba(44, 62, 80, 0.08);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.8);
}

.icon-create {
  background: linear-gradient(180deg, #fae1dd 0%, #f5c8ba 100%);
  border: 2rpx solid rgba(44, 62, 80, 0.08);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.8);
}

/* 图标内容 - 课程管理：三横线 */
.icon-manage .icon-inner {
  width: 36rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 999rpx;
  box-shadow: 0 12rpx 0 var(--primary), 0 -12rpx 0 var(--primary);
}

/* 图标内容 - 数据统计：柱状图 */
.icon-stats .icon-inner {
  display: flex;
  align-items: flex-end;
  gap: 5rpx;
  height: 32rpx;
}

.icon-stats .icon-inner::before,
.icon-stats .icon-inner::after {
  content: "";
  display: block;
  border-radius: 3rpx;
  background: var(--primary);
}

.icon-stats .icon-inner::before {
  width: 10rpx;
  height: 20rpx;
}

.icon-stats .icon-inner::after {
  width: 10rpx;
  height: 32rpx;
}

/* 用第三个伪元素（通过 box-shadow 模拟第三根柱子） */
.icon-stats .icon-inner {
  position: relative;
}

.icon-stats .icon-inner::before {
  box-shadow: 15rpx 0 0 var(--primary);
  width: 10rpx;
  height: 12rpx;
}

.icon-stats .icon-inner::after {
  width: 10rpx;
  height: 28rpx;
  position: relative;
}

/* 图标内容 - 创建课程：加号 */
.icon-create .icon-inner {
  width: 32rpx;
  height: 4rpx;
  background: var(--accent);
  border-radius: 999rpx;
  position: relative;
}

.icon-create .icon-inner::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 4rpx;
  height: 32rpx;
  margin-top: -16rpx;
  margin-left: -2rpx;
  background: var(--accent);
  border-radius: 999rpx;
}

/* 图标背景色 - 笔记 */
.icon-notes {
  background: linear-gradient(180deg, #e5ece7 0%, #cfdccf 100%);
  border: 2rpx solid rgba(44, 62, 80, 0.08);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.8);
}

/* 图标内容 - 笔记：文档+横线 */
.icon-notes .icon-inner {
  width: 22rpx;
  height: 28rpx;
  border: 3rpx solid var(--primary);
  border-radius: 3rpx;
  position: relative;
}

.icon-notes .icon-inner::after {
  content: "";
  position: absolute;
  top: 7rpx;
  left: 4rpx;
  width: 14rpx;
  height: 2rpx;
  background: var(--primary);
  box-shadow: 0 6rpx 0 var(--primary);
}

/* 图标背景色 - 评论 */
.icon-comments {
  background: linear-gradient(180deg, #e7eef4 0%, #d5e2ee 100%);
  border: 2rpx solid rgba(44, 62, 80, 0.08);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.8);
}

/* 图标内容 - 评论：气泡 */
.icon-comments .icon-inner {
  width: 28rpx;
  height: 20rpx;
  border: 3rpx solid var(--primary);
  border-radius: 6rpx;
  position: relative;
}

.icon-comments .icon-inner::after {
  content: "";
  position: absolute;
  bottom: -7rpx;
  left: 6rpx;
  width: 0;
  height: 0;
  border-left: 4rpx solid transparent;
  border-right: 4rpx solid transparent;
  border-top: 6rpx solid var(--primary);
}

/* 图标背景色 - 问答 */
.icon-qa {
  background: linear-gradient(180deg, #efe7d3 0%, #e4d2a8 100%);
  border: 2rpx solid rgba(44, 62, 80, 0.08);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.8);
}

/* 图标内容 - 问答：问号圆圈 */
.icon-qa .icon-inner {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid var(--primary);
  border-radius: 50%;
  position: relative;
}

.icon-qa .icon-inner::after {
  content: "?";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -55%);
  font-size: 20rpx;
  font-weight: 700;
  color: var(--primary);
  font-family: "Times New Roman", serif;
  line-height: 1;
}

.shortcut-text {
  font-size: 24rpx;
  color: var(--ink-dark);
  font-weight: 600;
  line-height: 1.3;
  text-align: center;
}

/* ===== 账号信息 ===== */
.info-card {
  padding: 8rpx 0;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 22rpx 28rpx 22rpx 36rpx;
  border-bottom: 1rpx solid var(--primary-light);
  gap: 20rpx;
}

.info-row:last-child {
  border-bottom: none;
}

/* 行首小图标 */
.info-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  position: relative;
}

/* 用户名图标：人物轮廓 */
.info-icon-user {
  background: linear-gradient(135deg, #e7eef4, #d5e2ee);
}

.info-icon-user::before {
  content: "";
  position: absolute;
  top: 8rpx;
  left: 50%;
  width: 12rpx;
  height: 12rpx;
  margin-left: -6rpx;
  border: 2rpx solid var(--primary);
  border-radius: 50%;
}

.info-icon-user::after {
  content: "";
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  width: 20rpx;
  height: 10rpx;
  margin-left: -10rpx;
  border: 2rpx solid var(--primary);
  border-radius: 10rpx 10rpx 0 0;
  border-bottom: none;
}

/* 昵称图标：标签 */
.info-icon-nick {
  background: linear-gradient(135deg, #efe7d3, #e4d2a8);
}

.info-icon-nick::before {
  content: "";
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 20rpx;
  height: 14rpx;
  border: 2rpx solid var(--primary);
  border-radius: 3rpx;
}

.info-icon-nick::after {
  content: "";
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  width: 8rpx;
  height: 8rpx;
  border: 2rpx solid var(--primary);
  border-radius: 50%;
}

/* 邮箱图标：信封 */
.info-icon-email {
  background: linear-gradient(135deg, #e5ece7, #cfdccf);
}

.info-icon-email::before {
  content: "";
  position: absolute;
  top: 10rpx;
  left: 8rpx;
  width: 24rpx;
  height: 16rpx;
  border: 2rpx solid var(--primary);
  border-radius: 2rpx;
}

.info-icon-email::after {
  content: "";
  position: absolute;
  top: 10rpx;
  left: 8rpx;
  width: 24rpx;
  height: 12rpx;
  border-top: 2rpx solid var(--primary);
  border-left: 2rpx solid var(--primary);
  transform: rotate(-15deg);
  border-radius: 2rpx 0 0 0;
}

/* 手机图标 */
.info-icon-phone {
  background: linear-gradient(135deg, #fae1dd, #f5c8ba);
}

.info-icon-phone::before {
  content: "";
  position: absolute;
  top: 6rpx;
  left: 12rpx;
  width: 16rpx;
  height: 24rpx;
  border: 2rpx solid var(--primary);
  border-radius: 4rpx;
}

.info-icon-phone::after {
  content: "";
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  width: 6rpx;
  height: 6rpx;
  margin-left: -3rpx;
  background: var(--primary);
  border-radius: 50%;
}

.info-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 26rpx;
  color: var(--ink-medium);
}

.info-value {
  font-size: 26rpx;
  color: var(--ink-dark);
  font-weight: 500;
}

/* ===== 退出登录 ===== */
.logout-btn {
  margin-top: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 28rpx;
  color: var(--accent);
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.logout-btn:active {
  opacity: 0.7;
}

.logout-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(to right, transparent, var(--accent), transparent);
}
